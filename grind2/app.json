{
  "expo": {
    "name": "NLogN",
    "slug": "grind",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "grind",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F0F"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.gaurangsharma.nlogn",
      "adaptiveIcon": {
        "backgroundColor": "#0F0F0F",
        "foregroundImage": "./assets/adaptive-icon.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "158ac38d-ddfc-42b3-83fc-3f3c35d8597e"
      }
    },
    "owner": "gaurang_sharma"
  }
}
